{
  "port": 8080,
  "timeout_seconds": 15,
  "max_requests_per_minute": 100,
  "jwt": {
    "issuer": "ptit-backend",
    "audience": "ptit-gateway"
  },
  "cors": {
    "allowed_origins": ["http://localhost:3000"],
    "allowed_methods": ["GET", "POST", "PUT", "DELETE"],
    "allowed_headers": ["Content-Type", "Authorization"]
  },
  "__comment": "Đây là VÍ DỤ cấu hình Gateway. Nó đóng vai trò làm BFF định tuyến từ port 8080 đến các Microservices cấp dưới. CÓ THỂ THAY ĐỔI SAU",
  "endpoints": [
    {
      "__comment_users": "=== USER SERVICE - PORT 8081 ===",
      "endpoint": "/api/users/login",
      "method": "POST",
      "backend": [
        {
          "host": ["http://localhost:8081"],
          "url_pattern": "/api/users/login"
        }
      ]
    },
    {
      "endpoint": "/api/users/{id}",
      "method": "GET",
      "auth_required": true,
      "backend": [
        {
          "host": ["http://localhost:8081"],
          "url_pattern": "/api/users/{id}"
        }
      ]
    },
    {
      "__comment_posts": "=== POST SERVICE - PORT 8082 ===",
      "endpoint": "/api/posts",
      "method": "GET",
      "cache_ttl_seconds": 60,
      "backend": [
        {
          "host": ["http://localhost:8082"],
          "url_pattern": "/api/posts"
        }
      ]
    },
    {
      "endpoint": "/api/posts/new",
      "method": "POST",
      "auth_required": true,
      "required_roles": ["admin", "teacher"],
      "backend": [
        {
          "host": ["http://localhost:8082"],
          "url_pattern": "/api/posts/new"
        }
      ]
    },
    {
      "__comment_groups": "=== GROUP SERVICE - PORT 8083 ===",
      "endpoint": "/api/groups",
      "method": "GET",
      "auth_required": true,
      "backend": [
        {
          "host": ["http://localhost:8083"],
          "url_pattern": "/api/groups"
        }
      ]
    }
  ]
}
